<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Sonder.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/sonder_night</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.Sonder</item>
    </style>

    <style name="Theme.Sonder" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
</resources>
